{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WiCiPlannerOutput",
  "type": "object",
  "required": ["planMarkdown", "measureSh", "checksSh", "steps", "benchmark"],
  "properties": {
    "summary": { "type": "string" },
    "planMarkdown": { "type": "string" },
    "measureSh": { "type": "string" },
    "checksSh": { "type": "string" },
    "benchmark": {
      "type": "object",
      "required": ["tool", "command", "metric", "min_reps", "warmup_discarded", "reason"],
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "metric": { "type": "string" },
        "min_reps": { "type": "integer", "minimum": 1 },
        "warmup_discarded": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool"],
            "properties": {
              "tool": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "validation"],
        "properties": {
          "id": { "type": "string", "pattern": "^S[0-9]+$" },
          "text": { "type": "string" },
          "experiments": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "string" },
          "environment": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
